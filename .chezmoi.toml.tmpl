{{- $hosttypeChoices := list "desktop" "work" -}}
{{- $hosttype := promptChoiceOnce . "hosttype" "What type of host are you on" $hosttypeChoices -}}

[git]
    autoCommit = true
    autoPush = true

[data]
    ntfy_topic = {{ promptStringOnce . "ntfy_topic" "ntfy.sh topic" | quote }}
    email = {{ promptStringOnce . "email" "Email address" | quote }}
    hosttype = {{ $hosttype | quote }}
