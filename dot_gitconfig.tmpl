[core]
	excludesfile = ~/.gitignore
	editor = nvim 
    eol = native
	autocrlf = input
[user]
	email = {{ .email | quote }}
	name = adamszegedi
	signingkey = {{ .signkey | quote }}
[commit]
	gpgsign = true
[pull]
	ff = only
[push]
    autoSetupRemote = true
[fetch]
	prune = true
[init]
	defaultBranch = main
[alias]
    graph = log --oneline --graph --decorate
[blame]
    date = short
