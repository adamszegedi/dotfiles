{

  "layer": "top",
  "position": "top", 
  "height": 37,
  
  "modules-left":   ["wlr/workspaces", "wlr/taskbar"],
  "modules-center": [],
  "modules-right":  ["tray", "pulseaudio", "network", "clock#date", "clock#time"],

  "wlr/taskbar": {
	"format": "{icon} {app_id}",
	"icon-size": 14,
	"icon-theme": "Papirus",
	"tooltip-format": "{title}",
	"on-click": "activate",
	"on-click-middle": "close",
  "on-click-right": "minimize-raise",
	"ignore-list": [
	    "Alacritty"
	],
	"app_ids-mapping": {
	}
  },

  "wlr/workspaces": {
    // "disable-scroll": true,
    "sort-by-number": true,
    //"all-outputs": true,
    "on-click": "activate",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "format": "{icon}",
    "format-icons": {
      "1": "<span color=\"#EBDBB2\">оћ•</span>",
      "2": "<span color=\"#EBDBB2\">п‰©</span>",
      "3": "<span color=\"#EBDBB2\">оџ…</span>",
      "4": "<span color=\"#EBDBB2\">о—ї</span>",
      "5": "<span color=\"#EBDBB2\">пЎ </span>",
      "6": "<span color=\"#EBDBB2\">у°‡љ</span>",
      "7": "<span color=\"#EBDBB2\">п†¶</span>",
      "8": "<span color=\"#EBDBB2\">п†ј</span>",
      "9": "<span color=\"#EBDBB2\">пћџ</span>",
      "urgent": "пЃЄ",
      "focused": "",
      "default": ""
    }
  },

  "tray": {
    "icon-size": 14,
    "spacing": 10
  },

  "clock#time": {
    "interval": 1,
    "format": " пЂ—   {:%H:%M} ",
    "tooltip": false
  },

  "clock#date": {
    "interval": 10,
    "format": " пЃі   {:%e %b %y} ", // icon: calendar-alt
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  },

  "network": {
    "format-wifi": " пЄЁ {essid} ",
    "format-ethernet": " п›ї  {ipaddr} ",
    "format-linked": "{ifname} (no ip) пћ– ",
    "format-disconnected": " пЄ© disconnected ",
    "tooltip-format-wifi": "signal strenght: {signalstrength}% | down speed: {bandwidthdownbits}, up speed: {bandwidthupbits}"
  },

  "pulseaudio": {
    "format": "{icon} {volume}% ",
    "format-muted": " пЂ¦  muted ",
    "scroll-step": 5,
    "on-click": "pactl set-sink-mute 0 toggle",
    "on-click-middle": "pavucontrol",
    "on-click-right": "~/.config/hypr/scripts/pactl_toggle.sh",
    "format-icons": {
      "headphone": " пЂҐ  ",
      "hands-free": " пЂҐ  ",
      "headset": " пЂҐ  ",
      "phone": " п‚•  ",
      "portable": " п‚•  ",
      "car": " п†№   ",
      "default": [" пЂ¦  ", " пЂ§  ", " п©Ѕ ", " пЂЁ  "]
    }
  },

  "mpd": {
    "format": " {stateIcon}   {artist} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S})   пЂЃ ",
    "format-disconnected": " Disconnected пЂЃ ",
    "format-stopped": " Stopped пЂЃ ",
    "interval": 2,
    "consume-icons": {
      "on": "пѓ„ " // Icon shows only when "consume" is on
    },
    "random-icons": {
      "off": "<span color=\"#fb4934\">пЃґ </span>", // Icon grayed out when "random" is off
      "on": "пЃґ "
    },
    "repeat-icons": {
      "on": "пЂћ "
    },
    "single-icons": {
      "on": "пЂћ1 "
    },
    "state-icons": {
      "paused": "пЃЊ",
      "playing": "пЃ‹"
    },
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous",
    "tooltip-format": "MPD (connected)",
    "tooltip-format-disconnected": "MPD (disconnected)"
  }
}

