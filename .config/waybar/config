{

  "layer": "top",
  "position": "top", 
  "margin": "6 6 0 6", 
  "modules-left":   ["wlr/workspaces"],
  "modules-center": [],
  "modules-right":  ["tray", "pulseaudio", "network", "clock#time"],

  "wlr/taskbar": {
	"format": "{icon} {app_id}",
	"icon-size": 18,
	"icon-theme": "Papirus",
	"tooltip-format": "{title}",
	"on-click": "activate",
	"on-click-middle": "close",
    "on-click-right": "minimize-raise",
	"ignore-list": [
	    "Alacritty"
	],
	"app_ids-mapping": {
	}
  },

  "wlr/workspaces": {
    "disable-scroll": true,
    "sort-by-number": true,
    //"all-outputs": true,
    "on-click": "activate",
    "format": "{icon}",
    "format-icons": {
      "1": "ΎΕι",
      "2": "≤░Ψθ",
      "3": "Όατ",
      "4": "ΎΒ╗",
      "5": "ΎΛυ",
      "6": "ΎΑβ",
      "7": "ΎΗ╖",
      "8": "ΎΖς",
      "9": "ΎΖ║",
      "urgent": "ΎΒς",
      "focused": "ΎΗΤ",
      "default": "ΎΕΝ"
    }
  },

  "tray": {
    "icon-size": 14,
    "spacing": 10
  },

  "clock#time": {
    "interval": 1,
    "format": " ΎΑΩ  {:%H:%M} ",
    "tooltip": false
  },

  "network": {
    "format-wifi": " ΎΘτ {essid} ",
    "format-ethernet": " {ifname} ΎΔΒ ",
    "format-linked": "{ifname} (no ip) ΎηΨ ",
    "format-disconnected": " Ύςσ disconnected ",
    "tooltip-format-wifi": "signal strenght: {signalstrength}% | down speed: {bandwidthdownbits}, up speed: {bandwidthupbits}"
  },

  "pulseaudio": {
    "format": "{icon} {volume}% ",
    "format-muted": " ΎΑο  muted ",
    "scroll-step": 5,
    "on-click": "pactl set-sink-mute 0 toggle",
    "on-click-middle": "pavucontrol",
    "on-click-right": "~/.config/hypr/scripts/pactl_toggle.sh",
    "format-icons": {
      "headphone": " ΎΑξ  ",
      "hands-free": " ΎΑξ  ",
      "headset": " ΎΑξ  ",
      "phone": " ΎΓΧ  ",
      "portable": " ΎΓΧ  ",
      "car": " ΎΗ╣   ",
      "default": [" ΎΑο  ", " ΎΑπ  ", " Ύσ╜ ", " ΎΑρ  "]
    }
  },
}

